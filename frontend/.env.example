# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Supabase Configuration (for direct client access if needed)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# LIFF Configuration
VITE_LIFF_ID=your_main_liff_id
VITE_LIFF_SCHEDULE_ID=your_liff_schedule_app_id
VITE_LIFF_CLOCK_ID=your_liff_clock_app_id
VITE_LIFF_LEAVE_ID=your_liff_leave_app_id
VITE_LIFF_PROFILE_ID=your_liff_profile_app_id
VITE_LIFF_LINK_ID=your_liff_link_app_id

# App Configuration
VITE_APP_NAME=Security Guard HRM
VITE_DEFAULT_LANGUAGE=th

# LIFF Development Mode
# Set to 'true' to allow accessing /liff pages through browser (testing only)
# WARNING: Set to 'false' for production deployment
VITE_LIFF_DEV_MODE=false
